## ---- 13. Per-mAb three-fraction plot -----------------------
make_fraction_plot <- function(this_mab) {
  df_reps  <- counts_all      %>% filter(mAb==this_mab, !is.na(f_Ab))
  df_means <- fraction_summary %>% filter(mAb==this_mab)
  df_curve <- curves           %>% filter(mAb==this_mab)
  df_fit   <- fit_results      %>% filter(mAb==this_mab)
  if (nrow(df_means)==0) return(NULL)
  
  this_group  <- competition_groups_join$group[competition_groups_join$mAb==this_mab]
  this_colour <- if (length(this_group)>0 && this_group %in% names(group_colours))
    group_colours[[this_group]] else "black"
  is_no_bind  <- this_mab %in% no_binding_mabs
  
  reps_long <- df_reps %>%
    select(mAb_nM, f_Ab, f_1_1, f_1_2) %>%
    pivot_longer(c(f_Ab,f_1_1,f_1_2), names_to="species", values_to="fraction") %>%
    mutate(species=case_when(species=="f_Ab"~"free_mAb",
                             species=="f_1_1"~"complex_1_1",
                             species=="f_1_2"~"complex_1_2"))
  
  means_long <- df_means %>%
    select(mAb_nM,
           free_mAb_mean=f_Ab_mean,    free_mAb_sd=f_Ab_sd,
           complex_1_1_mean=f_1_1_mean, complex_1_1_sd=f_1_1_sd,
           complex_1_2_mean=f_1_2_mean, complex_1_2_sd=f_1_2_sd) %>%
    pivot_longer(-mAb_nM,
                 names_to=c("species",".value"),
                 names_pattern="(free_mAb|complex_1_1|complex_1_2)_(mean|sd)")
  
  curve_long <- df_curve %>%
    select(mAb_nM, f_Ab, f_1_1, f_1_2) %>%
    pivot_longer(c(f_Ab,f_1_1,f_1_2), names_to="species", values_to="fraction") %>%
    mutate(species=case_when(species=="f_Ab"~"free_mAb",
                             species=="f_1_1"~"complex_1_1",
                             species=="f_1_2"~"complex_1_2"))
  
  sub_text <- if (is_no_bind) {
    "No binding detected"
  } else if (nrow(df_fit)>0 && isTRUE(df_fit$converged)) {
    sprintf("K<sub>d1</sub> = %.1f \u00b1 %.1f nM<br>K<sub>d2</sub> = %.1f \u00b1 %.1f nM<br>R\u00b2 = %.3f (global fit)",
            df_fit$Kd1_fit_nM, df_fit$Kd1_fit_SE,
            df_fit$Kd2_fit_nM, df_fit$Kd2_fit_SE,
            df_fit$r2_global)
  } else {
    "No convergence"
  }
  
  p <- ggplot() +
    geom_point(data=reps_long, aes(x=mAb_nM, y=fraction, colour=species),
               size=1.5, alpha=0.35, shape=1) +
    { if (nrow(curve_long)>0)
      geom_line(data=curve_long, aes(x=mAb_nM, y=fraction, colour=species),
                linewidth=1.2) } +
    geom_point(data=means_long, aes(x=mAb_nM, y=mean, colour=species), size=3.5) +
    geom_errorbar(data=means_long,
                  aes(x=mAb_nM, ymin=pmax(mean-sd,0), ymax=pmin(mean+sd,1), colour=species),
                  width=0.8) +
    scale_colour_manual(values=species_colours, labels=species_labels, name="Species") +
    scale_x_continuous(name="[mAb] (nM)", breaks=c(4,10,20,40),
                       limits=c(4, max(all_concs)*1.2)) +
    scale_y_continuous(name="Fraction of\nmAb-containing species",
                       limits=c(0,1), breaks=seq(0,1,0.25)) +
    labs(title=this_mab, subtitle=sub_text) +
    theme_classic(base_size=48) +
    theme(
      plot.title    = element_text(face="bold", size=44, colour=this_colour),
      plot.subtitle = ggtext::element_markdown(size=34, colour="black",
                                               hjust=0, lineheight=1.3),
      axis.title.x  = element_text(size=38, colour="black"),
      axis.title.y  = element_text(size=38, colour="black", angle=90, hjust=0.5),
      axis.text     = element_text(size=38, colour="black"),
      legend.title  = element_text(size=34, face="bold"),
      legend.text   = element_text(size=38),
      legend.position  = "right",
      panel.grid.major = element_line(colour="grey92", linewidth=0.3),
      panel.grid.minor = element_line(colour="grey96", linewidth=0.15),
      plot.margin      = margin(40, 15, 20, 10)
    )
  p
}

## ---- 14. Flextable summary table ---------------------------
make_kd_flextable <- function(fit_res, filepath_png, filepath_csv) {
  
  kd_tbl <- fit_res %>%
    mutate(
      Kd1   = case_when(no_binding~NA_real_, converged~round(Kd1_fit_nM,2), TRUE~NA_real_),
      SE1   = case_when(no_binding~NA_real_, converged~round(Kd1_fit_SE,2), TRUE~NA_real_),
      Kd2   = case_when(no_binding~NA_real_, converged~round(Kd2_fit_nM,2), TRUE~NA_real_),
      SE2   = case_when(no_binding~NA_real_, converged~round(Kd2_fit_SE,2), TRUE~NA_real_),
      Kd2_Kd1 = case_when(no_binding~NA_real_,
                          converged~round(Kd2_fit_nM/Kd1_fit_nM,2), TRUE~NA_real_),
      R2    = case_when(converged~round(r2_global,3), TRUE~NA_real_),
      Note  = case_when(no_binding~"No binding", !converged~"No convergence", TRUE~"")
    ) %>%
    arrange(group, Kd1) %>%
    select(mAb, group, Kd1, SE1, Kd2, SE2, Kd2_Kd1, R2, Note)
  
  write.csv(kd_tbl, filepath_csv, row.names=FALSE)
  
  tbl_disp <- kd_tbl %>%
    mutate(
      Kd1      = ifelse(is.na(Kd1),     "\u2014", sprintf("%.2f", Kd1)),
      SE1      = ifelse(is.na(SE1),     "\u2014", sprintf("%.2f", SE1)),
      Kd2      = ifelse(is.na(Kd2),     "\u2014", sprintf("%.2f", Kd2)),
      SE2      = ifelse(is.na(SE2),     "\u2014", sprintf("%.2f", SE2)),
      Kd2_Kd1  = ifelse(is.na(Kd2_Kd1),"\u2014", sprintf("%.2f", Kd2_Kd1)),
      R2       = ifelse(is.na(R2),      "\u2014", sprintf("%.3f", R2)),
      Note     = ifelse(is.na(Note)|Note=="", "\u2014", Note)
    )
  
  row_colours <- tbl_disp$group
  nr <- nrow(tbl_disp)
  
  ft <- flextable(tbl_disp) %>%
    set_header_labels(
      mAb      = "mAb",
      group    = "Group",
      Kd1      = "Kd1 (nM)",
      SE1      = "SE1 (nM)",
      Kd2      = "Kd2 (nM)",
      SE2      = "SE2 (nM)",
      Kd2_Kd1  = "Kd2/Kd1",
      R2       = "R\u00b2",
      Note     = "Note"
    ) %>%
    compose(part="header", j="Kd1",
            value=as_paragraph("K", as_sub("d1"), " (nM)")) %>%
    compose(part="header", j="SE1",
            value=as_paragraph("SE", as_sub("1"), " (nM)")) %>%
    compose(part="header", j="Kd2",
            value=as_paragraph("K", as_sub("d2"), " (nM)")) %>%
    compose(part="header", j="SE2",
            value=as_paragraph("SE", as_sub("2"), " (nM)")) %>%
    compose(part="header", j="Kd2_Kd1",
            value=as_paragraph("K", as_sub("d2"), "/K", as_sub("d1"))) %>%
    compose(part="header", j="R2",
            value=as_paragraph("R\u00b2")) %>%
    border_remove() %>%
    border_outer(part = "all",  border = fp_border(color = "black", width = 1.5)) %>%
    hline(part = "header", i = 1,
          border = fp_border(color = "black", width = 1.5)) %>%
    hline(part = "body", i = seq_len(nr - 1),
          border = fp_border(color = "black", width = 0.5)) %>%
    vline(part = "all", border = fp_border(color = "black", width = 0.5)) %>%
    vline_right(part = "all",
                border = fp_border(color = "black", width = 1.5)) %>%
    align(part="header", align="center") %>%
    align(part="body",   align="center") %>%
    align(part="body", j="mAb",  align="left") %>%
    align(part="body", j="Note", align="left") %>%
    font(part="all", fontname="Arial") %>%
    fontsize(part="header", size=11) %>%
    fontsize(part="body",   size=10) %>%
    bold(part="header") %>%
    color(i = which(row_colours == "GP1"),   color = group_colours[["GP1"]],   part="body") %>%
    color(i = which(row_colours == "GPC-A"), color = group_colours[["GPC-A"]], part="body") %>%
    color(i = which(row_colours == "GPC-B"), color = group_colours[["GPC-B"]], part="body") %>%
    color(i = which(row_colours == "GPC-C"), color = group_colours[["GPC-C"]], part="body") %>%
    width(j="mAb",      width=1.2) %>%
    width(j="group",    width=0.7) %>%
    width(j="Kd1",      width=0.85) %>%
    width(j="SE1",      width=0.85) %>%
    width(j="Kd2",      width=0.85) %>%
    width(j="SE2",      width=0.85) %>%
    width(j="Kd2_Kd1",  width=0.75) %>%
    width(j="R2",       width=0.6) %>%
    width(j="Note",     width=1.0) %>%
    height_all(height=0.28) %>%
    hrule(rule="exact") %>%
    padding(padding.top=4, padding.bottom=4,
            padding.left=6, padding.right=6, part="all")
  
  save_as_image(ft, path=filepath_png, res=300)
  message("Flextable saved: ", filepath_png)
  invisible(ft)
}

## ---- 15. Summary dot/bar plots -----------------------------
make_summary_plots_v35 <- function(fit_res, dir_out) {
  
  results_conv <- fit_res %>%
    filter(converged) %>%
    mutate(Kd1_low=pmax(Kd1_fit_nM-Kd1_fit_SE,0.01), Kd1_high=Kd1_fit_nM+Kd1_fit_SE,
           Kd2_low=pmax(Kd2_fit_nM-Kd2_fit_SE,0.01), Kd2_high=Kd2_fit_nM+Kd2_fit_SE)
  group_levels <- intersect(names(group_colours),unique(results_conv$group))
  
  make_dot_plot <- function(kd_col,low_col,high_col,title_expr,y_label) {
    df_plot <- results_conv %>% arrange(group,.data[[kd_col]]) %>%
      mutate(mAb=factor(mAb,levels=mAb))
    ggplot(df_plot,aes(x=mAb,y=.data[[kd_col]],colour=group)) +
      geom_point(size=4,shape=16) +
      geom_errorbar(aes(ymin=.data[[low_col]],ymax=.data[[high_col]]),width=0.25) +
      scale_colour_manual(values=group_colours,name="Competition group") +
      scale_y_log10(name=y_label,breaks=c(0.1,1,10,100,1000),
                    labels=c("0.1","1","10","100","1000")) +
      scale_x_discrete(name=NULL) +
      labs(title=title_expr) +
      theme_classic(base_size=48) +
      theme(axis.text.x  = element_text(angle=45, hjust=1, size=38, colour="black"),
            axis.text.y  = element_text(size=38, colour="black"),
            axis.title   = element_text(size=48, colour="black"),
            legend.position = "right",
            legend.title = element_text(size=48),
            legend.text  = element_text(size=38),
            plot.title   = element_text(face="bold", size=48, colour="black"),
            panel.grid.major = element_line(colour="grey92", linewidth=0.3),
            panel.grid.minor = element_line(colour="grey96", linewidth=0.15))
  }
  
  p_dot_Kd1 <- make_dot_plot("Kd1_fit_nM","Kd1_low","Kd1_high",
                             expression(italic(K)[d1]~"by mAb (global cubic fit)"),
                             expression(italic(K)[d1]~"(nM)"))
  p_dot_Kd2 <- make_dot_plot("Kd2_fit_nM","Kd2_low","Kd2_high",
                             expression(italic(K)[d2]~"by mAb (global cubic fit)"),
                             expression(italic(K)[d2]~"(nM)"))
  ggsave(file.path(dir_out,"Kd1_dotplot_by_mAb.png"), plot=p_dot_Kd1,
         width=14, height=9, dpi=600)
  ggsave(file.path(dir_out,"Kd2_dotplot_by_mAb.png"), plot=p_dot_Kd2,
         width=14, height=9, dpi=600)
  
  make_bar_plot <- function(kd_col,title_expr,y_label,show_pval=FALSE) {
    df_plot <- results_conv %>% mutate(group=factor(group,levels=group_levels))
    grp_sum <- df_plot %>% group_by(group) %>%
      summarise(mean_val=mean(.data[[kd_col]],na.rm=TRUE),
                sd_val=sd(.data[[kd_col]],na.rm=TRUE),n_mabs=n(),.groups="drop") %>%
      mutate(low_val=pmax(mean_val-sd_val,0.01),high_val=mean_val+sd_val)
    group_pairs <- combn(group_levels,2,simplify=FALSE); n_pairs<-length(group_pairs)
    mw_res <- lapply(group_pairs,function(pair){
      g1<-pair[1];g2<-pair[2]
      v1<-df_plot[[kd_col]][df_plot$group==g1];v2<-df_plot[[kd_col]][df_plot$group==g2]
      if(length(v1)<2||length(v2)<2)
        return(data.frame(group1=g1,group2=g2,p_raw=NA_real_,p_adjusted=NA_real_,
                          label="insufficient n",stringsAsFactors=FALSE))
      wt<-wilcox.test(v1,v2,exact=FALSE)
      data.frame(group1=g1,group2=g2,p_raw=wt$p.value,p_adjusted=NA_real_,
                 label=NA_character_,stringsAsFactors=FALSE)
    })
    sig_table<-do.call(rbind,mw_res)
    sig_table$p_adjusted<-pmin(sig_table$p_raw*n_pairs,1)
    if (show_pval) {
      sig_table$label <- ifelse(is.na(sig_table$p_adjusted) | sig_table$p_adjusted > 0.05,
                                "ns", paste0("p = ", sprintf("%.3f", sig_table$p_adjusted)))
    } else {
      sig_table$label <- sig_label(sig_table$p_adjusted)
    }
    group_x<-setNames(seq_along(group_levels),group_levels)
    sig_plot<-sig_table %>% filter(!is.na(p_raw)) %>%
      mutate(x1=group_x[group1],x2=group_x[group2],span=abs(x2-x1)) %>% arrange(span)
    max_val<-max(grp_sum$high_val,na.rm=TRUE)
    sig_plot$bracket_y<-max_val*(1.6^seq_len(nrow(sig_plot)))
    p<-ggplot()+
      geom_col(data=grp_sum,aes(x=group,y=mean_val,fill=group),alpha=0.7,width=0.4)+
      geom_errorbar(data=grp_sum,aes(x=group,ymin=low_val,ymax=high_val),
                    width=0.12,linewidth=0.35)+
      geom_point(data=df_plot,aes(x=group,y=.data[[kd_col]]),size=2,shape=21,
                 fill="white",colour="black")+
      ggrepel::geom_text_repel(data=df_plot,aes(x=group,y=.data[[kd_col]],label=sub("mAb ","",mAb)),
                               size=10,colour="black",hjust=1,nudge_x=-0.35,
                               direction="y",segment.color=NA,min.segment.length=Inf,max.overlaps=Inf)+
      geom_segment(data=sig_plot,aes(x=x1,xend=x1,y=bracket_y*0.92,yend=bracket_y),
                   colour="black",linewidth=0.4)+
      geom_segment(data=sig_plot,aes(x=x2,xend=x2,y=bracket_y*0.92,yend=bracket_y),
                   colour="black",linewidth=0.4)+
      geom_segment(data=sig_plot,aes(x=x1,xend=x2,y=bracket_y,yend=bracket_y),
                   colour="black",linewidth=0.4)+
      geom_text(data=sig_plot,aes(x=(x1+x2)/2,y=bracket_y*1.05,label=label),
                colour="black",size=17,vjust=0)+
      scale_fill_manual(values=group_colours,guide="none")+
      scale_y_log10(name=y_label,
                    breaks=c(0.1,1,10,100,1000),
                    labels=c("0.1","1","10","100","1000")) +
      scale_x_discrete(name="Competition group",limits=group_levels,
                       expand=expansion(add=c(0.8, 0.3)))+
      labs(title=title_expr)+
      theme_classic(base_size=48)+
      theme(plot.title  = element_text(face="bold", size=48, colour="black"),
            axis.title  = element_text(size=48, colour="black"),
            axis.text   = element_text(size=38, colour="black"),
            panel.grid.major = element_line(colour="grey92", linewidth=0.3),
            panel.grid.minor = element_line(colour="grey96", linewidth=0.15),
            plot.margin = margin(30, 10, 10, 10))   # ← a bit of space at top
    list(plot=p,sig_table=sig_table)
  }
  
  bar_Kd1 <- make_bar_plot("Kd1_fit_nM",
                           expression(italic(K)[d1]~"by Competition Group"),
                           expression(italic(K)[d1]~"(nM)"))
  bar_Kd2 <- make_bar_plot("Kd2_fit_nM",
                           expression(italic(K)[d2]~"by Competition Group"),
                           expression(italic(K)[d2]~"(nM)"))
  
  ggsave(file.path(dir_out,"Kd1_barplot_by_group.png"), plot=bar_Kd1$plot,
         width=14, height=16, dpi=600, bg="white")
  ggsave(file.path(dir_out,"Kd2_barplot_by_group.png"), plot=bar_Kd2$plot,
         width=14, height=16, dpi=600, bg="white")
  
  bar_Kd1_pval <- make_bar_plot("Kd1_fit_nM",
                                expression(italic(K)[d1]~"by Competition Group"),
                                expression(italic(K)[d1]~"(nM)"), show_pval=TRUE)
  bar_Kd2_pval <- make_bar_plot("Kd2_fit_nM",
                                expression(italic(K)[d2]~"by Competition Group"),
                                expression(italic(K)[d2]~"(nM)"), show_pval=TRUE)
  
  ggsave(file.path(dir_out,"Kd1_barplot_by_group_pval.png"), plot=bar_Kd1_pval$plot,
         width=14, height=16, dpi=600, bg="white")
  ggsave(file.path(dir_out,"Kd2_barplot_by_group_pval.png"), plot=bar_Kd2_pval$plot,
         width=14, height=16, dpi=600, bg="white")
  write.csv(bar_Kd1$sig_table,file.path(dir_out,"significance_table_Kd1.csv"),row.names=FALSE)
  write.csv(bar_Kd2$sig_table,file.path(dir_out,"significance_table_Kd2.csv"),row.names=FALSE)
  
  panel_bar <- plot_grid(bar_Kd1$plot, bar_Kd2$plot,
                         ncol=2, labels=c("A)","B)"),
                         label_size=34, label_fontface="bold")
  ggsave(file.path(dir_out,"Kd1_Kd2_barplot_panel.png"),
         plot=panel_bar, width=28, height=9, dpi=600, bg="white")
  message("Panelled bar plot saved: Kd1_Kd2_barplot_panel.png")
}

