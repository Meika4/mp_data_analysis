## ---- 7. Cubic solver ---------------------------------------
solve_cAg_free <- function(Kd1, Kd2, c_Ab_tot, c_Ag_tot) {
  if (Kd1<=0||Kd2<=0) return(NA_real_)
  Ka1 <- 1/Kd1; Ka2 <- 1/Kd2
  a <- Ka1*Ka2
  b <- Ka1 + 2*Ka1*Ka2*c_Ab_tot - Ka1*Ka2*c_Ag_tot
  c <- 1 + Ka1*c_Ab_tot - Ka1*c_Ag_tot
  d <- -c_Ag_tot
  rts <- tryCatch(polyroot(c(d,c,b,a)), error=function(e) NULL)
  if (is.null(rts)) return(NA_real_)
  real_rts <- Re(rts)[abs(Im(rts))<1e-6]
  valid    <- real_rts[real_rts>=0 & real_rts<=c_Ag_tot*1.0001]
  if (length(valid)==0) return(NA_real_)
  min(valid)
}

predict_fractions <- function(Kd1, Kd2, c_Ab_tot_vec, c_Ag_tot) {
  out <- data.frame(c_Ab_tot=c_Ab_tot_vec,
                    f_Ab=NA_real_, f_1_1=NA_real_, f_1_2=NA_real_)
  for (i in seq_along(c_Ab_tot_vec)) {
    c_Ab_tot <- c_Ab_tot_vec[i]
    c_Ag     <- solve_cAg_free(Kd1, Kd2, c_Ab_tot, c_Ag_tot)
    if (is.na(c_Ab_tot)||c_Ab_tot==0||is.na(c_Ag)) next
    Ka1 <- 1/Kd1; Ka2 <- 1/Kd2
    c_Ab_free <- c_Ab_tot / (1 + Ka1*c_Ag + Ka1*Ka2*c_Ag^2)
    if (!is.finite(c_Ab_free)||c_Ab_free<0) next
    c11 <- Ka1*c_Ab_free*c_Ag; c12 <- Ka1*Ka2*c_Ab_free*c_Ag^2
    tot <- c_Ab_free+c11+c12
    if (tot<=0) next
    out$f_Ab[i]  <- c_Ab_free/tot
    out$f_1_1[i] <- c11/tot
    out$f_1_2[i] <- c12/tot
  }
  out
}

## ---- 8. Global fit ------------------------------------------
fit_global <- function(this_mab, data) {
  if (this_mab %in% no_binding_mabs) {
    return(data.frame(mAb=this_mab, Kd1_fit_nM=NA_real_, Kd1_fit_SE=NA_real_,
                      Kd2_fit_nM=NA_real_, Kd2_fit_SE=NA_real_,
                      r2_global=NA_real_, n_points=0L, converged=FALSE, no_binding=TRUE))
  }
  df_fit <- data %>%
    filter(mAb==this_mab, counts_mAb_total>=30,
           !is.na(f_Ab), !is.na(f_1_1), !is.na(f_1_2), mAb_nM>0)
  if (nrow(df_fit)<3) {
    return(data.frame(mAb=this_mab, Kd1_fit_nM=NA_real_, Kd1_fit_SE=NA_real_,
                      Kd2_fit_nM=NA_real_, Kd2_fit_SE=NA_real_,
                      r2_global=NA_real_, n_points=nrow(df_fit), converged=FALSE, no_binding=FALSE))
  }
  residuals_fn <- function(par, df) {
    Kd1<-par[["Kd1"]]; Kd2<-par[["Kd2"]]
    if (Kd1<=0||Kd2<=0) return(rep(1e6,3*nrow(df)))
    pred <- predict_fractions(Kd1, Kd2, df$mAb_nM, MDS7_total_nM)
    if (anyNA(pred$f_Ab)||anyNA(pred$f_1_1)||anyNA(pred$f_1_2)) return(rep(1e6,3*nrow(df)))
    c(df$f_Ab-pred$f_Ab, df$f_1_1-pred$f_1_1, df$f_1_2-pred$f_1_2)
  }
  fit <- tryCatch(
    nls.lm(par=list(Kd1=median(df_fit$mAb_nM), Kd2=median(df_fit$mAb_nM)*2),
           lower=c(Kd1=0.001,Kd2=0.001), upper=c(Kd1=1e5,Kd2=1e5),
           fn=residuals_fn, df=df_fit,
           control=nls.lm.control(maxiter=500,ftol=1e-9)),
    error=function(e) NULL)
  if (is.null(fit)) {
    return(data.frame(mAb=this_mab, Kd1_fit_nM=NA_real_, Kd1_fit_SE=NA_real_,
                      Kd2_fit_nM=NA_real_, Kd2_fit_SE=NA_real_,
                      r2_global=NA_real_, n_points=nrow(df_fit), converged=FALSE, no_binding=FALSE))
  }
  cov_mat <- tryCatch(vcov(fit), error=function(e) NULL)
  if (!is.null(cov_mat)&&all(diag(cov_mat)>=0)) {
    se_vals <- sqrt(diag(cov_mat)); se_Kd1<-se_vals[["Kd1"]]; se_Kd2<-se_vals[["Kd2"]]
  } else { se_Kd1<-NA_real_; se_Kd2<-NA_real_ }
  Kd1<-fit$par[["Kd1"]]; Kd2<-fit$par[["Kd2"]]
  pred <- predict_fractions(Kd1, Kd2, df_fit$mAb_nM, MDS7_total_nM)
  obs  <- c(df_fit$f_Ab, df_fit$f_1_1, df_fit$f_1_2)
  pre  <- c(pred$f_Ab,   pred$f_1_1,   pred$f_1_2)
  ss_res <- sum((obs-pre)^2, na.rm=TRUE)
  ss_tot <- sum((obs-mean(obs,na.rm=TRUE))^2, na.rm=TRUE)
  r2 <- if (ss_tot>0) round(1-ss_res/ss_tot,3) else NA_real_
  data.frame(mAb=this_mab, Kd1_fit_nM=Kd1, Kd1_fit_SE=se_Kd1,
             Kd2_fit_nM=Kd2, Kd2_fit_SE=se_Kd2, r2_global=r2,
             n_points=nrow(df_fit), converged=TRUE, no_binding=FALSE)
}

