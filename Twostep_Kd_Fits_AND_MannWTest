for (i in seq_len(nrow(fit_results))) {
  r <- fit_results[i,]
  if (r$no_binding)      { message("  ", r$mAb, ": no binding") }
  else if (!r$converged) { message("  ", r$mAb, ": did not converge (n=", r$n_points, ")") }
  else { message("  ", r$mAb, ": Kd1=", round(r$Kd1_fit_nM,1), "+/-", round(r$Kd1_fit_SE,1),
                 " | Kd2=", round(r$Kd2_fit_nM,1), "+/-", round(r$Kd2_fit_SE,1),
                 " | R2=", r$r2_global) }
}

