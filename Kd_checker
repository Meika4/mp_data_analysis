## ---- 3. Load and parse data --------------------------------
raw <- read.csv(input_file,
                header           = TRUE,
                check.names      = FALSE,
                stringsAsFactors = FALSE,
                na.strings       = "NA")

colnames(raw)[1:2] <- c("row_idx", "Measurement_Name")

dat <- raw %>%
  filter(grepl("mAb.*[Mm][Dd][Ss]7 Monomer", Measurement_Name, ignore.case = TRUE)) %>%
  mutate(Measurement_Name = sub("^[0-9]+_", "", Measurement_Name))

parse_name <- function(name) {
  name_clean <- str_squish(name)
  mab  <- str_extract(name_clean, "mAb [0-9]+\\.[0-9]+[A-Z]")
  conc <- as.numeric(
    str_match(name_clean,
              "mAb [0-9]+\\.[0-9]+[A-Z]\\s+([0-9]+)\\s*nM")[, 2])
  rep  <- str_extract(name_clean, "[IVX]+$")
  data.frame(mAb = mab, mAb_nM = conc, replicate = rep,
             stringsAsFactors = FALSE)
}

meta <- do.call(rbind, lapply(dat$Measurement_Name, parse_name))
dat  <- cbind(meta, dat)
dat  <- dat %>% filter(mAb_nM %in% all_concs)

## ---- 4. Extract Gaussian peak counts -----------------------
extract_peaks <- function(row) {
  peaks <- list()
  for (i in 1:8) {
    pos_col <- paste0(i, ": Mass position (kDa) - Gaussian Overlay")
    abs_col <- paste0(i, ": Mass absolute count - Gaussian Overlay")
    if (!pos_col %in% names(row)) next
    pos     <- suppressWarnings(as.numeric(trimws(as.character(row[[pos_col]]))))
    abs_val <- suppressWarnings(as.numeric(trimws(as.character(row[[abs_col]]))))
    if (length(pos) == 1 && length(abs_val) == 1 &&
        !is.na(pos) && !is.na(abs_val) && pos > 0)
      peaks[[length(peaks) + 1]] <- data.frame(
        peak = i, mass_kDa = pos, abs_count = abs_val)
  }
  if (length(peaks) == 0) return(NULL)
  do.call(rbind, peaks)
}

all_peaks <- lapply(seq_len(nrow(dat)), function(i) {
  pk <- extract_peaks(dat[i, ])
  if (is.null(pk)) return(NULL)
  cbind(dat[i, c("mAb", "mAb_nM", "replicate", "Measurement_Name")], pk)
})
peaks_df <- do.call(rbind, all_peaks)

## ---- 5. Assign species by kDa window -----------------------
assign_species <- function(mass) {
  case_when(
    mass >= 60  & mass <= 100 ~ "free_MDS7",
    mass >= 130 & mass <= 180 ~ "free_mAb",
    mass >= 185 & mass <= 235 ~ "complex_1_1",
    mass >= 240 & mass <= 330 ~ "complex_1_2",
    TRUE                      ~ "other"
  )
}
peaks_df <- peaks_df %>% mutate(species = assign_species(mass_kDa))

## ---- 6. Pivot: one row per measurement ---------------------
species_counts <- peaks_df %>%
  filter(species != "other") %>%
  group_by(mAb, mAb_nM, replicate, Measurement_Name, species) %>%
  slice_max(abs_count, n = 1, with_ties = FALSE) %>%
  ungroup() %>%
  select(mAb, mAb_nM, replicate, Measurement_Name, species, abs_count) %>%
  pivot_wider(names_from = species, values_from = abs_count, values_fill = 0)

for (col in c("free_MDS7", "free_mAb", "complex_1_1", "complex_1_2")) {
  if (!col %in% names(species_counts)) species_counts[[col]] <- 0
}

## ---- 7. Calculate single-shot Kd1 and Kd2 -----------------
kd_data <- species_counts %>%
  filter(!mAb %in% no_binding_mabs) %>%
  mutate(
    total_mAb_counts = free_mAb + complex_1_1 + complex_1_2,
    f_conv        = ifelse(total_mAb_counts > 0, mAb_nM / total_mAb_counts, NA_real_),
    conc_mAb_free = free_mAb    * f_conv,
    conc_1_1      = complex_1_1 * f_conv,
    conc_1_2      = complex_1_2 * f_conv,
    conc_M_free   = MDS7_total_nM - conc_1_1 - 2 * conc_1_2,
    Kd1 = ifelse(conc_1_1 > 0 & conc_M_free > 0 & !is.na(f_conv),
                 conc_mAb_free * conc_M_free / conc_1_1, NA_real_),
    Kd2 = ifelse(conc_1_2 > 0 & conc_M_free > 0 & !is.na(f_conv),
                 conc_1_1 * conc_M_free / conc_1_2, NA_real_),
    frac_bound  = (conc_1_1 + conc_1_2) / mAb_nM,
    coop_ratio  = Kd2 / Kd1
  ) %>%
  filter(!is.na(Kd1), conc_M_free > 0, total_mAb_counts > 0) %>%
  left_join(cg_join, by = "mAb")

## ---- 8. Linear regression per mAb --------------------------
calc_lm <- function(x, y) {
  df <- data.frame(x = x, y = y) %>% filter(!is.na(y))
  if (nrow(df) < 3) return(list(slope     = NA_real_,
                                intercept = NA_real_,
                                r2        = NA_real_,
                                p         = NA_real_,
                                n         = nrow(df)))
  fit <- lm(y ~ x, data = df)
  s   <- summary(fit)
  list(slope     = coef(fit)[2],
       intercept = coef(fit)[1],
       r2        = s$r.squared,
       p         = coef(s)[2, 4],
       n         = nrow(df))
}

lm_results <- kd_data %>%
  group_by(mAb, group, clone) %>%
  summarise(
    kd1_lm    = list(calc_lm(mAb_nM, Kd1)),
    Kd1_mean  = mean(Kd1, na.rm = TRUE),
    Kd1_sd    = sd(Kd1,   na.rm = TRUE),
    kd2_lm    = list(calc_lm(mAb_nM, Kd2)),
    Kd2_mean  = mean(Kd2, na.rm = TRUE),
    Kd2_sd    = sd(Kd2,   na.rm = TRUE),
    coop_mean = mean(coop_ratio, na.rm = TRUE),
    .groups   = "drop"
  ) %>%
  mutate(
    kd1_slope = map_dbl(kd1_lm, ~.x$slope),
    kd1_r2    = map_dbl(kd1_lm, ~.x$r2),
    kd1_p     = map_dbl(kd1_lm, ~.x$p),
    kd2_slope = map_dbl(kd2_lm, ~.x$slope),
    kd2_r2    = map_dbl(kd2_lm, ~.x$r2),
    kd2_p     = map_dbl(kd2_lm, ~.x$p),
    verdict = case_when(
      is.na(kd1_r2)                          ~ "Insufficient data",
      kd1_r2 >= 0.50 | kd1_p <= 0.05        ~ "TRENDING",
      kd1_r2 >= 0.20 & kd1_p  > 0.05        ~ "CAUTION",
      TRUE                                   ~ "VALID"
    )
  )

