)

make_pvalue_flextable <- function(lm_res, filepath_png, filepath_csv) {
  
  tbl <- lm_res %>%
    transmute(
      mAb       = clone,        # ← changed from Clone = clone
      Group     = group,
      Kd1_slope = kd1_slope,
      Kd1_R2    = kd1_r2,
      Kd1_p     = kd1_p,
      Kd2_slope = kd2_slope,
      Kd2_R2    = kd2_r2,
      Kd2_p     = kd2_p,
      Verdict   = verdict
    ) %>%
    arrange(Group, mAb)
  
  write.csv(tbl, filepath_csv, row.names = FALSE)
  
  tbl_disp <- tbl %>%
    mutate(
      Kd1_slope = ifelse(is.na(Kd1_slope), "\u2014", sprintf("%.2f", Kd1_slope)),
      Kd1_R2    = ifelse(is.na(Kd1_R2),    "\u2014", sprintf("%.3f", Kd1_R2)),
      Kd1_p     = sapply(Kd1_p, fmt_p_cell),
      Kd2_slope = ifelse(is.na(Kd2_slope), "\u2014", sprintf("%.2f", Kd2_slope)),
      Kd2_R2    = ifelse(is.na(Kd2_R2),    "\u2014", sprintf("%.3f", Kd2_R2)),
      Kd2_p     = sapply(Kd2_p, fmt_p_cell)
    )
  
  row_colours  <- tbl_disp$Group
  nr           <- nrow(tbl_disp)
  kd1_sig_rows <- which(tbl$Kd1_p <= 0.05 & !is.na(tbl$Kd1_p))
  kd2_sig_rows <- which(tbl$Kd2_p <= 0.05 & !is.na(tbl$Kd2_p))
  
  ft <- flextable(tbl_disp) %>%
    compose(part = "header", j = "Kd1_slope",
            value = as_paragraph("K", as_sub("d1"), " slope")) %>%
    compose(part = "header", j = "Kd1_R2",
            value = as_paragraph("K", as_sub("d1"), " R\u00b2")) %>%
    compose(part = "header", j = "Kd1_p",
            value = as_paragraph("K", as_sub("d1"), " p")) %>%
    compose(part = "header", j = "Kd2_slope",
            value = as_paragraph("K", as_sub("d2"), " slope")) %>%
    compose(part = "header", j = "Kd2_R2",
            value = as_paragraph("K", as_sub("d2"), " R\u00b2")) %>%
    compose(part = "header", j = "Kd2_p",
            value = as_paragraph("K", as_sub("d2"), " p")) %>%
    border_remove() %>%
    border_outer(part = "all",  border = fp_border(color = "black", width = 1.5)) %>%
    hline(part = "header", i = 1,
          border = fp_border(color = "black", width = 1.5)) %>%
    hline(part = "body", i = seq_len(nr - 1),
          border = fp_border(color = "black", width = 0.5)) %>%
    vline(part = "all", border = fp_border(color = "black", width = 0.5)) %>%
    vline_right(part = "all",
                border = fp_border(color = "black", width = 1.5)) %>%
    align(part = "header", align = "center") %>%
    align(part = "body",   align = "center") %>%
    align(part = "body", j = "mAb",     align = "left") %>%   # ← changed from "Clone"
    align(part = "body", j = "Verdict", align = "left") %>%
    font(part = "all", fontname = "Arial") %>%
    fontsize(part = "header", size = 11) %>%
    fontsize(part = "body",   size = 10) %>%
    bold(part = "header") %>%
    color(i = which(row_colours == "GP1"),
          color = group_colours[["GP1"]],   part = "body") %>%
    color(i = which(row_colours == "GPC-A"),
          color = group_colours[["GPC-A"]], part = "body") %>%
    color(i = which(row_colours == "GPC-B"),
          color = group_colours[["GPC-B"]], part = "body") %>%
    color(i = which(row_colours == "GPC-C"),
          color = group_colours[["GPC-C"]], part = "body") %>%
    { ft_tmp <- .
    if (length(kd1_sig_rows) > 0)
      ft_tmp <- ft_tmp %>%
        color(i = kd1_sig_rows, j = "Kd1_p",
              color = "#CC0000", part = "body") %>%
        bold(i  = kd1_sig_rows, j = "Kd1_p", part = "body")
    if (length(kd2_sig_rows) > 0)
      ft_tmp <- ft_tmp %>%
        color(i = kd2_sig_rows, j = "Kd2_p",
              color = "#CC0000", part = "body") %>%
        bold(i  = kd2_sig_rows, j = "Kd2_p", part = "body")
    ft_tmp } %>%
    width(j = "mAb",      width = 0.80) %>%   # ← changed from "Clone"
    width(j = "Group",     width = 0.65) %>%
    width(j = "Kd1_slope", width = 0.85) %>%
    width(j = "Kd1_R2",    width = 0.75) %>%
    width(j = "Kd1_p",     width = 0.75) %>%
    width(j = "Kd2_slope", width = 0.85) %>%
    width(j = "Kd2_R2",    width = 0.75) %>%
    width(j = "Kd2_p",     width = 0.75) %>%
    width(j = "Verdict",   width = 1.00) %>%
    height_all(height = 0.28) %>%
    hrule(rule = "exact") %>%
    padding(padding.top = 4, padding.bottom = 4,
            padding.left = 6, padding.right = 6, part = "all")
  
  save_as_image(ft, path = filepath_png, res = 300)
  message("p-value flextable saved: ", filepath_png)
  invisible(ft)
}

