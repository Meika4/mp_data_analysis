plot_kd_combined <- function(mab_name, kd_df, lm_df, out_dir) {
  
  this_kd <- kd_df %>% filter(mAb == mab_name)
  this_lm <- lm_df %>% filter(mAb == mab_name)
  if (nrow(this_kd) == 0) return(invisible(NULL))
  
  grp   <- this_lm$group[1]
  clone <- this_lm$clone[1]
  col   <- unname(group_colours[grp])
  
  kd1_slope <- this_lm$kd1_slope
  kd1_r2    <- this_lm$kd1_r2
  kd1_p     <- this_lm$kd1_p
  kd2_slope <- this_lm$kd2_slope
  kd2_r2    <- this_lm$kd2_r2
  kd2_p     <- this_lm$kd2_p
  
  fmt_p <- function(pv) {
    if (is.na(pv)) return("NA")
    if (pv < 0.001) return("<0.001")
    sprintf("%.3f", pv)
  }
  
  ann1 <- sprintf(
    "K<sub>d1</sub>:  slope = %.2f  |  R\u00b2 = %.3f  |  p = %s",
    ifelse(is.na(kd1_slope), 0, kd1_slope),
    ifelse(is.na(kd1_r2),    0, kd1_r2),
    fmt_p(kd1_p))
  
  ann2 <- if (!is.na(kd2_r2)) {
    sprintf(
      "K<sub>d2</sub>:  slope = %.2f  |  R\u00b2 = %.3f  |  p = %s",
      ifelse(is.na(kd2_slope), 0, kd2_slope),
      ifelse(is.na(kd2_r2),    0, kd2_r2),
      fmt_p(kd2_p))
  } else "K<sub>d2</sub>:  insufficient data"
  
  means_kd1 <- this_kd %>% filter(!is.na(Kd1)) %>%
    group_by(mAb_nM) %>%
    summarise(m = mean(Kd1), s = replace_na(sd(Kd1), 0), .groups = "drop")
  means_kd2 <- this_kd %>% filter(!is.na(Kd2)) %>%
    group_by(mAb_nM) %>%
    summarise(m = mean(Kd2), s = replace_na(sd(Kd2), 0), .groups = "drop")
  
  p <- ggplot() +
    geom_point(data = this_kd %>% filter(!is.na(Kd1)),
               aes(x = mAb_nM, y = Kd1),
               shape = 16, size = 2.5, colour = col, alpha = 0.45) +
    geom_point(data = means_kd1, aes(x = mAb_nM, y = m),
               shape = 16, size = 4, colour = col) +
    geom_errorbar(data = means_kd1,
                  aes(x = mAb_nM, ymin = m - s, ymax = m + s),
                  colour = col, width = 0.8) +
    geom_smooth(data = this_kd %>% filter(!is.na(Kd1)),
                aes(x = mAb_nM, y = Kd1),
                method = "lm", formula = y ~ x, se = FALSE,
                colour = col, linewidth = 0.9, linetype = "solid") +
    geom_point(data = this_kd %>% filter(!is.na(Kd2)),
               aes(x = mAb_nM, y = Kd2),
               shape = 22, size = 2.5, colour = col, fill = "white",
               stroke = 0.8, alpha = 0.45) +
    { if (nrow(means_kd2) > 0) list(
      geom_point(data = means_kd2, aes(x = mAb_nM, y = m),
                 shape = 22, size = 4, colour = col,
                 fill = "white", stroke = 1.2),
      geom_errorbar(data = means_kd2,
                    aes(x = mAb_nM, ymin = m - s, ymax = m + s),
                    colour = col, width = 0.8, linetype = "dashed")
    )} +
    { if (sum(!is.na(this_kd$Kd2)) >= 3)
      geom_smooth(data = this_kd %>% filter(!is.na(Kd2)),
                  aes(x = mAb_nM, y = Kd2),
                  method = "lm", formula = y ~ x, se = FALSE,
                  colour = col, linewidth = 0.9, linetype = "dashed") } +
    coord_cartesian(clip = "off") +
    annotate("segment", x = 28, xend = 33, y = 168, yend = 168,
             colour = col, linewidth = 0.9, linetype = "solid") +
    annotate("point",   x = 30.5, y = 168,
             shape = 16, size = 3, colour = col) +
    annotate("text",    x = 34, y = 168,
             label = expression(K[d1]), hjust = 0, size = 18, colour = "black") +
    annotate("segment", x = 28, xend = 33, y = 158, yend = 158,
             colour = col, linewidth = 0.9, linetype = "dashed") +
    annotate("point",   x = 30.5, y = 158,
             shape = 22, size = 3,
             colour = col, fill = "white", stroke = 1) +
    annotate("text",    x = 34, y = 158,
             label = expression(K[d2]), hjust = 0, size = 18, colour = "black") +
    scale_x_continuous(name = "[mAb] (nM)", breaks = all_concs,
                       limits = c(0, 45)) +
    scale_y_continuous(name = expression(italic(K)[d*",app"] ~ "(nM)"),
                       limits = c(0, 150), breaks = seq(0, 150, 25)) +
    labs(title    = paste0("mAb ", clone),
         subtitle = paste0(ann1, "<br>", ann2)) +
    theme_classic(base_size = 48) +
    theme(
      plot.title    = element_text(face = "bold", size = 48, colour = "black"),
      plot.subtitle = ggtext::element_markdown(size = 36, colour = "black",
                                               lineheight = 1.2),
      axis.title    = element_text(size = 48, colour = "black"),
      axis.text     = element_text(size = 38, colour = "black"),
      panel.grid.major = element_line(colour = "grey92", linewidth = 0.3),
      plot.margin   = margin(40, 15, 10, 10)
    )
  
  fname <- file.path(out_dir, paste0("Kd_diagnostic_", clone, ".png"))
  ggsave(fname, p, width = 14, height = 9, dpi = 600, bg = "white")
  cat("  Saved:", fname, "\n")
  return(invisible(p))
}

